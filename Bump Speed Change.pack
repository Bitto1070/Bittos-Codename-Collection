Bump Speed Change.hx________PACKSEP________
function onEvent(e) if (e.event.name == "Bump Speed Change") {
	var params = e.event.params;
	var abs = params[3];
	camZoomLerp = abs ? params[0] : Math.min(1,Flags.DEFAULT_ZOOM_LERP * params[0]);
	camGameZoomLerp = abs ? params[1] : Math.min(1,Flags.DEFAULT_CAM_ZOOM_LERP * params[1]);
	camHUDZoomLerp = abs ? params[2] : Math.min(1,Flags.DEFAULT_HUD_ZOOM_LERP * params[2]);
}
________PACKSEP________{
	"params": [
		{
			"name": "Bump Speed Multiplier",
			"type": "Float(0, 20, 0.01, 4)",
			"defaultValue": "1"
		},
		{
			"name": "CamGame Zoom Speed Multiplier",
			"type": "Float(0, 20, 0.01, 4)",
			"defaultValue": "1"
		},
		{
			"name": "CamHUD Zoom Speed Multiplier",
			"type": "Float(0, 20, 0.01, 4)",
			"defaultValue": "1"
		},
		{
			"name": "absolute lerp (0-1)?",
			"type": "Bool",
			"defaultValue": false
		}
	]
}________PACKSEP________
