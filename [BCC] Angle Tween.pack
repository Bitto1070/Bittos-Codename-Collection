[BCC] Angle Tween.hx________PACKSEP________//turnies
var angleTarget = 0;
var lerping = false;
function onEvent(e) if (e.event.name == "[BCC] Angle Tween") {
	var params = e.event.params;

	var timeroPre = Std.string(params[1]).split(":");
	if (timeroPre.length < 1 || timeroPre.length > 3) {
		trace("Invalid time setting!"); //if someone messes up
		return;
	}

	var beat = Conductor.crochet * 0.001;
	var step = beat * 0.25;
	var one = timeroPre[0];
	var two = timeroPre[1];
	var timero = switch (timeroPre.length) {
		case 1: step * one;
		case 2: beat * one + step * two;
		case 3: beat*4 * one + beat * two + step * timeroPre[2];
	}

	angleTarget = params[0];
	var ease = params[2];
	var angleEase = CoolUtil.flxeaseFromString(ease, params[3]);

	lerping = (ease == "lerp");
	FlxTween.cancelTweensOf(FlxG.camera, ["angle"]);
	//trace(timero,angleTarget,angleEase);
	if (lerping) return;
	switch (ease) {
		case "none (instant)","none (happens instantly)": FlxG.camera.angle = angleTarget;
		default: FlxTween.angle(FlxG.camera,FlxG.camera.angle,angleTarget,timero,{ease:angleEase, onUpdate: (a) -> FlxG.camera.angle = a.angle});
	}
}
function update() if (lerping && FlxG.camera.angle != angleTarget) FlxG.camera.angle = FlxMath.lerp(FlxG.camera.angle, angleTarget, camGameZoomLerp);
________PACKSEP________{
	"params": [
		{
			"name": "Angle Target",
			"type": "Float(-360,360,0.01,2)",
			"defaultValue": "0"
		},{
			"name": "Tween Time (M:B:S, B:S or S)",
			"type": "String",
			"defaultValue": "1:0"
		},{
			"name": "Tween Ease (ex: circ, quad, cube)",
			"type": "DropDown('none (instant)','lerp','linear', 'back', 'bounce', 'circ', 'cube', 'elastic', 'expo', 'quad', 'quart', 'quint', 'sine', 'smoothStep', 'smootherStep')",
			"defaultValue": "lerp"
		},{
			"name": "Tween Type (ex: InOut)",
			"type": "DropDown('In', 'Out', 'InOut')",
			"defaultValue": "Out"
		}
	]
