[BCC] Cinematic Bars.hx________PACKSEP________//cinemies
var barMult = 1.10001;
public var topCinematic = new FunkinSprite(0, 0).makeSolid(FlxG.width*2, FlxG.height*barMult, 0xFF000000);
public var bottomCinematic = new FunkinSprite(0, 0).makeSolid(FlxG.width*2, FlxG.height*barMult, 0xFF000000);

var cinemaBars = [];
function postCreate() {
	for (bar in [topCinematic,bottomCinematic]) {
		bar.camera = camHUD;
		bar.screenCenter(0x01);
		insert(0,bar);
		cinemaBars.push(bar);
	}
	topCinematic.y = -topCinematic.height;
	bottomCinematic.y = camHUD.height;
}

var lerpTarget = 0;
var lerpSpeed = 0.05;
var lerping = false;
function onEvent(e) if (e.event.name == "[BCC] Cinematic Bars") {
	var params = e.event.params;
	var overHUD = params[4];
	for (bar in cinemaBars) {
		FlxTween.cancelTweensOf(bar);
		remove(bar,true);
		if (overHUD) add(bar);
		else insert(0,bar);
	}
	var ease = params[2];
	lerping = ease == "lerp";

	var timeroPre = Std.string(params[1]).split(":");
	if (timeroPre.length < 1 || timeroPre.length > 3) {
		trace("Invalid time setting!"); //if someone messes up
		return;
	}

	var beat = Conductor.crochet * 0.001;
	var step = beat * 0.25;
	var timero = switch (timeroPre.length) {
		case 1: step * timeroPre[0];
		case 2: beat * timeroPre[0] + step * timeroPre[1];
		case 3: beat*4 * timeroPre[0] + beat * timeroPre[1] + step * timeroPre[2];
	}

	var height = params[0];
	var offset = params[6] ?? 0;
	topTarget = height - topCinematic.height + offset;
	bottomTarget = FlxG.height - height + offset;

	switch (ease) {
		case "none (instant)","none (happens instantly)":
			topCinematic.y = topTarget;
			bottomCinematic.y = bottomTarget;
		case "lerp":
			lerpTarget = height;
			lerpSpeed = params[5];
		default:
			var barEase = CoolUtil.flxeaseFromString(ease,params[3]);
			FlxTween.tween(topCinematic,{y:topTarget},timero,{ease:barEase});
			FlxTween.tween(bottomCinematic,{y:bottomTarget},timero,{ease:barEase});
	}
}

var topTarget = 0;
var bottomTarget = 0;
function update() if (lerping && (topCinematic.y != topTarget && bottomCinematic.y != bottomTarget)) {
	topCinematic.y = lerp(topCinematic.y,topTarget,lerpSpeed);
	bottomCinematic.y = lerp(bottomCinematic.y,bottomTarget,lerpSpeed);
}
________PACKSEP________{
	"params": [
		{
			"name": "Height Target (pixels, 0 to 361 (off to blocks entire screen)",
			"type": "Float(0, 361, 0.01, 2)",
			"defaultValue": 120
		},{
			"name": "Tween Time (M:B:S, B:S or S)",
			"type": "String",
			"defaultValue": "1:0"
		},{
			"name": "Tween Ease",
			"type": "DropDown('none (instant)','linear', 'lerp', 'back', 'bounce', 'circ', 'cube', 'elastic', 'expo', 'quad', 'quart', 'quint', 'sine', 'smoothStep', 'smootherStep')",
			"defaultValue": "circ"
		},{
			"name": "Tween Type",
			"type": "DropDown('In', 'Out', 'InOut')",
			"defaultValue": "Out"
		},{
			"name": "Go over HUD",
			"type": "Bool",
			"defaultValue": false
		},{
			"name": "(for 'lerp' ease) lerp speed",
			"type": "String",
			"defaultValue": "0.05"
		},{
			"name": "Y offset",
			"type": "Float(-720, 720, 0.01, 2)",
			"defaultValue": 0
		}
	]
